{
  "manifest_version": 3,
  "name": "Billy Blocksi: Enterprise Filter",
  "version": "1.2",
  "description": "Professional high-speed classroom management engine.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "browsingData",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ublock_base",
        "enabled": true,
        "path": "ublock-filters.json"
      },
      {
        "id": "easylist_base",
        "enabled": true,
        "path": "easylist.json"
      },
      {
        "id": "billy_static",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "blocked.html"
  }
}
